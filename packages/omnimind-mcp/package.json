{
  "name": "@boardroom/omnimind-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "OmniMind MCP server — cross-agent memory layer via Model Context Protocol",
  "main": "dist/index.js",
  "bin": {
    "omnimind-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx src/smoke.ts",
    "keygen": "tsx src/keygen.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@boardroom/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "undici": "^7.10.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
