# BoardRoom Platform Development Environment
# Copy to .env and fill in your API keys

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/boardroom_dev"
REDIS_URL="redis://localhost:6379"

# JWT Authentication
JWT_SECRET="dev-jwt-secret-change-in-production"

# OmniMind API
OMNIMIND_API_KEY="dev-omnimind-api-key-local-only"
OMNIMIND_API_URL="http://localhost:3333"
OMNIMIND_PORT="3333"

# BoardRoom AI
BOARDROOM_PORT="3001"
CORS_ORIGINS="http://localhost:3001,http://localhost:5173"
APP_URL="http://localhost:3001"

# External API Keys (Required for development)
ANTHROPIC_API_KEY="your-anthropic-api-key-here"
OPENAI_API_KEY="your-openai-api-key-here"

# Optional APIs
DEEPGRAM_API_KEY="optional-deepgram-api-key"
STRIPE_SECRET_KEY="sk_test_your_stripe_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Environment
NODE_ENV="development"

# Encryption
ENCRYPTION_KEY="dev-encryption-key-32-characters-minimum-here"

# Admin allowlist (BoardRoom AI)
# Comma-separated User IDs allowed to access /admin/* routes. Leave empty to
# disable admin access entirely. See packages/boardroom-ai/server/src/middleware/require-admin.ts.
# TODO(post-launch): replace with an isAdmin claim on the JWT sourced from User.role.
ADMIN_USER_IDS=""

# Rate Limiting (Development-friendly settings)
SESSION_RATE_LIMIT_DISPATCHES=50
SESSION_RATE_LIMIT_CREATIONS=20
AUTH_RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
AUTH_RATE_LIMIT_MAX=100

# Feature Flags
ENABLE_STRIPE_MOCKING="false"
ENABLE_EXTERNAL_API_MOCKING="false"

# ----------------------------------------------------------------------------
# Wave 3 Track E — Auth completeness (UX-1.2 / UX-1.3 / UX-1.4)
# ----------------------------------------------------------------------------

# Google OAuth (LOGIN — scopes: openid email profile). Separate from the
# Google CALENDAR OAuth credentials (GOOGLE_CLIENT_ID/SECRET/REDIRECT_URI) so
# the two consent flows are independent.
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3001/auth/oauth/google/callback"

# GitHub OAuth (LOGIN — scopes: read:user user:email).
GITHUB_OAUTH_CLIENT_ID=""
GITHUB_OAUTH_CLIENT_SECRET=""
GITHUB_OAUTH_REDIRECT_URI="http://localhost:3001/auth/oauth/github/callback"

# Email verification (UX-1.4). When "true", verified-email is REQUIRED to
# access cost-bearing routes. Default unset/false = soft mode (banner only).
REQUIRE_VERIFIED_EMAIL="false"

# Password reset / email verify token secret. Defaults to JWT_SECRET when
# unset — set to a distinct value in production for blast-radius isolation.
PASSWORD_RESET_TOKEN_SECRET=""

# SMTP — used for password-reset and verify-email send. When SMTP_HOST is
# unset, mailer logs the body and no-ops (dev passthrough).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
