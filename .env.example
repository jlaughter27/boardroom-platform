# BoardRoom Platform Development Environment
# Copy to .env and fill in your API keys

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/boardroom_dev"
REDIS_URL="redis://localhost:6379"

# JWT Authentication
JWT_SECRET="dev-jwt-secret-change-in-production"

# OmniMind API
OMNIMIND_API_KEY="dev-omnimind-api-key-local-only"
OMNIMIND_API_URL="http://localhost:3333"
OMNIMIND_PORT="3333"

# BoardRoom AI
BOARDROOM_PORT="3001"
CORS_ORIGINS="http://localhost:3001,http://localhost:5173"
APP_URL="http://localhost:3001"

# External API Keys (Required for development)
ANTHROPIC_API_KEY="your-anthropic-api-key-here"
OPENAI_API_KEY="your-openai-api-key-here"

# Optional APIs
DEEPGRAM_API_KEY="optional-deepgram-api-key"
STRIPE_SECRET_KEY="sk_test_your_stripe_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Environment
NODE_ENV="development"

# Encryption
ENCRYPTION_KEY="dev-encryption-key-32-characters-minimum-here"

# Rate Limiting (Development-friendly settings)
SESSION_RATE_LIMIT_DISPATCHES=50
SESSION_RATE_LIMIT_CREATIONS=20
AUTH_RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
AUTH_RATE_LIMIT_MAX=100

# Feature Flags
ENABLE_STRIPE_MOCKING="false"
ENABLE_EXTERNAL_API_MOCKING="false"
