# Test Environment Configuration
# Copy to .env.test for local testing

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/boardroom_test"

# JWT Authentication
JWT_SECRET="test-jwt-secret-for-unit-tests-only"

# Stripe (Mocked in tests)
STRIPE_SECRET_KEY="sk_test_mocked"
STRIPE_WEBHOOK_SECRET="whsec_mocked"
STRIPE_PRICE_ID="price_mocked"

# External APIs (Mocked in tests)
ANTHROPIC_API_KEY="sk-ant-test-mocked"
OPENAI_API_KEY="sk-proj-test-mocked"
DEEPGRAM_API_KEY="dg_test_mocked"

# OmniMind API
OMNIMIND_API_KEY="test-api-key-for-unit-tests"
OMNIMIND_API_URL="http://localhost:3333"

# Application
NODE_ENV="test"
APP_URL="http://localhost:5173"
BOARDROOM_PORT="3002"
OMNIMIND_PORT="3334"

# Encryption
ENCRYPTION_KEY="test-encryption-key-32-characters-long-here"

# Rate Limiting (Reduced for tests)
SESSION_RATE_LIMIT_DISPATCHES=10
SESSION_RATE_LIMIT_CREATIONS=5
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# Feature Flags
ENABLE_STRIPE_MOCKING="true"
ENABLE_EXTERNAL_API_MOCKING="true"
